# ============================================================
#  Environment variables
# ============================================================
# There is NO server you host yourself — this is a static site + Supabase.
# Secrets live ONLY in Supabase Edge Function secrets (never in the repo,
# never in the browser).

# ---- Edge Function secrets (set with: supabase secrets set KEY=value) ----

# The ONLY secret you must set manually. A long random string used to derive
# each account's login credential from its PIN. Generate once and NEVER change
# it after users exist (changing it invalidates every PIN).
#   Generate:  openssl rand -hex 32
PIN_PEPPER=replace-with-a-64-char-random-hex-string

# These three are injected AUTOMATICALLY into Edge Functions by Supabase.
# You normally do NOT set them yourself; listed here for reference only.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=<anon public key>
# SUPABASE_SERVICE_ROLE_KEY=<service role key — SECRET, server-side only>

# ---- Frontend (browser) config ----
# These are PUBLIC and do NOT go in this file. Put them in
# hsk_flashcard_app/supabase-config.js:
#   window.SUPABASE_CONFIG = { url: "...", anonKey: "..." }
# Leave them blank to keep the app in local-only mode.
