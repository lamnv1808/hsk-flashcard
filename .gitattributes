# Line-ending policy (Phase 24E-B).
#
# core.autocrlf=true on Windows checks text files out as CRLF even though the
# committed blobs are LF. Several suites assert BYTE identity -- data.js against
# a pinned SHA-256, and packs/catalog.js against a freshly generated byte image
# -- so a CRLF checkout breaks them on a fresh clone while the repository itself
# is perfectly fine. Pinning eol=lf makes the working tree match the blob on
# every platform, so hashes are reproducible everywhere.
#
# This file declares intent only; it does not rewrite history or content.

# Byte-sensitive runtime data: pinned SHA-256 in tests/data/*.py.
hsk_flashcard_app/data.js text eol=lf

# All shipped runtime scripts, including the generated packs/catalog.js whose
# bytes are regenerated and compared by tests/data/test_pack_catalog_legacy.py.
hsk_flashcard_app/**/*.js text eol=lf

# Test and tooling sources.
tests/**/*.py text eol=lf
scripts/**/*.py text eol=lf

# Architecture/release documentation.
docs/**/*.md text eol=lf

# Web app manifest is parsed as text but shipped verbatim.
*.webmanifest text eol=lf

# Binary assets: never touch these. The workbook matters because its raw bytes
# are the documented basis for the HSK sourceChecksum in packs/catalog.js.
*.png binary
*.ico binary
*.xlsx binary
