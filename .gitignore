# Volatile test artifacts (regenerated by tests/run_regression.py; not source of truth)
tests/reports/

# Reproducible content-pack build artifacts (Phase 24D). Regenerated from the
# committed source plus the committed ID ledger, so committing them would add
# diff noise without adding information.
# NOT ignored, and must stay committed: the authoritative ID ledgers
# (source_data/**/<packId>-id-ledger.json) and the QA acceptance reports for
# real launch packs. The ledger is the sole card-identity authority -- if it
# were machine-local, card ids would stop being reproducible.
build/content-packs/

# Atomic-write temporaries. The importer and the pipeline both stage through
# these; an orphaned one would otherwise show up as a dirty working tree and
# fail the release checker.
*.tmp

# Python
__pycache__/
*.pyc

# OS / editor noise
.DS_Store
Thumbs.db
